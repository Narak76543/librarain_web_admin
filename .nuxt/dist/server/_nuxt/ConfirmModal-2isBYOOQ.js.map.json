{"file":"ConfirmModal-2isBYOOQ.js","mappings":";;;;;;;;;;;;;mBACOA,eAAAC,WAAA,EAAA,OAAM,sEAAqE,GAAA,MAAA,CAAA,uJAEhB,QAAA,KAAK,oEAClB,QAAA,OAAO,0SAa/C,QAAA,YAAY;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps"],"sources":["../../../../components/ConfirmModal.vue"],"sourcesContent":["<template>\r\n  <div class=\"fixed inset-0 bg-black/50 z-50 flex items-center justify-center p-4\">\r\n    <div class=\"card w-full max-w-md animate-in fade-in zoom-in duration-200\">\r\n      <h3 class=\"text-lg font-semibold text-text-primary mb-2\">{{ title }}</h3>\r\n      <p class=\"text-text-secondary mb-6 text-sm\">{{ message }}</p>\r\n      \r\n      <div class=\"flex justify-end gap-3\">\r\n        <button \r\n          @click=\"$emit('cancel')\"\r\n          class=\"h-10 px-4 rounded-lg font-medium text-sm text-text-primary hover:bg-surface transition-colors\"\r\n        >\r\n          Cancel\r\n        </button>\r\n        <button \r\n          @click=\"$emit('confirm')\"\r\n          class=\"h-10 px-4 rounded-lg font-medium text-sm bg-error text-white hover:bg-red-600 transition-colors\"\r\n        >\r\n          {{ confirmLabel }}\r\n        </button>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\ndefineProps({\r\n  title: { type: String, default: 'Confirm Action' },\r\n  message: { type: String, default: 'Are you sure you want to proceed?' },\r\n  confirmLabel: { type: String, default: 'Confirm' }\r\n})\r\n\r\ndefineEmits(['confirm', 'cancel'])\r\n</script>\r\n"],"version":3}