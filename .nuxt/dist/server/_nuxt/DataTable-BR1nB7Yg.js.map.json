{"file":"DataTable-BR1nB7Yg.js","mappings":";;;;;;;;;;;;;;AA0EA,UAAM,QAAQ;AAUd,UAAM,aAAa,SAAS,MAAM;AAChC,aAAO,KAAK,KAAK,MAAM,QAAQ,MAAM,OAAO;AAAA,IAC9C,CAAC;;AArFM,YAAA,OAAAA,eAAAC,WAAA,EAAA,OAAM,qEAAiE,MAAA,CAAA,CAAA,yLAAA;AAKhDC,oBAAA,QAAA,UAAP,QAAG;4BAAsDC,eAAA,CAAA,IAAI,OAAK,WAAA,CAAA,MACxEC,eAAA,IAAI,KAAK;;;oBAMO,QAAA,MAAI,CAAjB,KAAK,QAAG;+DAGU,MAAG,MAAA,EAAA,GAAA,4DAAA,CAAA,CAAA,YAAA;AAGXF,sBAAA,QAAA,UAAP,QAAG;AAAsD,gBAAA,cAAAC,eAAA,CAAA,IAAI,OAAK,WAAA,CAAA,CAAA,IAAA;AAC9DE,wBAAA,KAAA,QAAA,IAAI,KAAG,EAAG,IAAQ,GAAA,MAAA;oCAC1B,IAAI,IAAI,GAAG,CAAA,CAAA,EAAA;AAAA;;;;;;AAIT,UAAA,CAAA,QAAA,KAAK,QAAM;sCACf,WAAS,QAAA,QAAQ,MAAM,CAAA,kFAAA;AAAA;;;;UASzB,QAAA,QAAK,GAAA;wMAE8CD,gBAAA,QAAA,YAAY,QAAA,UAAO,CAAA,6DACzBA,eAAA,KAAK,IAAI,eAAO,QAAA,SAAS,QAAA,KAAK,CAAA,4EAC9B,QAAA,KAAK,gPAM5C,QAAA,SAAI,CAAA,IAAA,cAAA;AAMHF,sBAAA,WAAA,QAAL,MAAC;kCAGAC,eAAA,CAAA,MAAM,QAAA,OAAI,gDAAA,6DAAA,wFAAA,CAAA,qBAGf,CAAC;;AAIO,cAAA,qLAAAG,sBAAA,QAAA,SAAS,WAAA,KAAU,IAAA,cAAA,EAAA,8BAAA;AAAA;;;;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","_ssrRenderList","_ssrRenderClass","_ssrInterpolate","_ssrRenderSlot","_ssrIncludeBooleanAttr"],"sources":["../../../../components/DataTable.vue"],"sourcesContent":["<template>\r\n  <div class=\"w-full border border-border rounded-xl overflow-hidden bg-white\">\r\n    <div class=\"overflow-x-auto\">\r\n      <table class=\"w-full text-left text-sm\">\r\n        <thead class=\"bg-surface text-text-secondary text-xs font-semibold uppercase border-b border-border\">\r\n          <tr>\r\n            <th v-for=\"col in columns\" :key=\"col.key\" class=\"px-6 py-3\" :class=\"col.class\">\r\n              {{ col.label }}\r\n            </th>\r\n          </tr>\r\n        </thead>\r\n        <tbody class=\"divide-y divide-border\">\r\n          <tr \r\n            v-for=\"(row, idx) in rows\" \r\n            :key=\"idx\" \r\n            class=\"hover:bg-surface/50 transition-colors cursor-pointer group\"\r\n            :class=\"{'bg-surface/20': idx % 2 === 1}\"\r\n            @click=\"$emit('row-click', row)\"\r\n          >\r\n            <td v-for=\"col in columns\" :key=\"col.key\" class=\"px-6 py-4\" :class=\"col.class\">\r\n              <slot :name=\"col.key\" :row=\"row\">\r\n                {{ row[col.key] }}\r\n              </slot>\r\n            </td>\r\n          </tr>\r\n          <tr v-if=\"!rows.length\">\r\n            <td :colspan=\"columns.length\" class=\"px-6 py-8 text-center text-text-secondary\">\r\n              No data available\r\n            </td>\r\n          </tr>\r\n        </tbody>\r\n      </table>\r\n    </div>\r\n    \r\n    <!-- Pagination -->\r\n    <div v-if=\"total > 0\" class=\"flex items-center justify-between px-6 py-4 border-t border-border bg-white\">\r\n      <p class=\"text-sm text-text-secondary\">\r\n        Showing <span class=\"font-semibold text-text-primary\">{{ (page - 1) * perPage + 1 }}</span>\r\n        to <span class=\"font-semibold text-text-primary\">{{ Math.min(page * perPage, total) }}</span>\r\n        of <span class=\"font-semibold text-text-primary\">{{ total }}</span> results\r\n      </p>\r\n      \r\n      <div class=\"flex gap-1\">\r\n        <button \r\n          class=\"w-8 h-8 flex items-center justify-center rounded border border-border text-text-secondary hover:bg-surface disabled:opacity-50 disabled:cursor-not-allowed\"\r\n          :disabled=\"page === 1\"\r\n          @click=\"$emit('page-change', page - 1)\"\r\n        >\r\n          &lt;\r\n        </button>\r\n        <button \r\n          v-for=\"p in totalPages\" \r\n          :key=\"p\"\r\n          class=\"w-8 h-8 flex items-center justify-center rounded text-sm font-medium transition-colors\"\r\n          :class=\"p === page ? 'bg-primary text-white border border-primary' : 'border border-border text-text-secondary hover:bg-surface'\"\r\n          @click=\"$emit('page-change', p)\"\r\n        >\r\n          {{ p }}\r\n        </button>\r\n        <button \r\n          class=\"w-8 h-8 flex items-center justify-center rounded border border-border text-text-secondary hover:bg-surface disabled:opacity-50 disabled:cursor-not-allowed\"\r\n          :disabled=\"page === totalPages\"\r\n          @click=\"$emit('page-change', page + 1)\"\r\n        >\r\n          &gt;\r\n        </button>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\nimport { computed } from 'vue'\r\n\r\nconst props = defineProps({\r\n  columns: { type: Array, required: true },\r\n  rows: { type: Array, required: true },\r\n  total: { type: Number, default: 0 },\r\n  page: { type: Number, default: 1 },\r\n  perPage: { type: Number, default: 10 }\r\n})\r\n\r\ndefineEmits(['page-change', 'row-click'])\r\n\r\nconst totalPages = computed(() => {\r\n  return Math.ceil(props.total / props.perPage)\r\n})\r\n</script>\r\n"],"version":3}