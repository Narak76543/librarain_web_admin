QAAY,MAAK;AAAA;;QACnD,OAAM;AAAA,QAAgB,OAAOA,MAAA,KAAA,EAAM;AAAA,QAAa,MAAK;AAAA;;QACrD,OAAM;AAAA,QAAe,OAAOA,MAAA,KAAA,EAAM;AAAA,QAAY,MAAK;AAAA;;QACnD,OAAM;AAAA,QAAiB,OAAK,IAAMA,MAAA,KAAA,EAAM,aAAa,eAAc,CAAA;AAAA,QAAM,MAAK;AAAA;;AAWjEC,oBAAA,IAAL,MAAC;6BAA+BC,cAAA,OAAK,IAAC,KAAA,KAAA,EAAA,aAAuBA,cAAA,OAAK,IAAC,KAAA,KAAA,EAAA;;AAO7E,YAAA,kEAAAA,cAAA,UAAQ,WAAA,KAAU,CAAA,qEAAA;oBAOI,OAAA,OAAM,CAArB,OAAO,QAAG;sCAEjB,MAAI,MAAM,CAAC,kBACX,MAAI,MAAM,CAAC;;;AASWD,oBAAAD,MAAA,SAAA,EAAU,QAAM,CAA/B,OAAO,QAAG;sBAEjBE,cAAA,KAAG,MAAG,MAAA,EAAA,mFAMJ,KAAK;;;oBAaiB,YAAA,OAAW,CAA1B,OAAO,QAAG;oCAEjB,KAAG,MAAM,IAAI,kBACb,QAAM,MAAM,KAAK;;AAKf,YAAA,kLAAAC,eAAAH,MAAA,KAAA,EAAM,UAAU,CAAA,iKAAA;oBASK,YAAA,OAAW,CAA1B,OAAO,QAAG;+FACwCI,eAAA,EAAA,iBAAA,MAAM,MAAK,CAAA,sDAC3BD,eAAA,MAAM,KAAK,yEACSA,eAAA,MAAM,KAAK;;;;QAWxE,IAAG;AAAA,QAAU,OAAM;AAAA;yBAA7B,CAAuF,GAAAE,QAAAC,UAAA,aAAA;;;;;8BAAnB,UAAQ;AAAA;;;;;;;QAG3E,SAAS;AAAA,QACT,MAAM,aAAA;AAAA;QAEI,gBAAX,CAEW,EAAA,IAAA,GAAAD,QAAAC,UAAA,aAAA;;;cADK,QAAQ,IAAI;AAAA;;;cAA1BC,YAAoC,wBAAA;AAAA,gBAAtB,QAAQ,IAAI;AAAA;;;;QAEjB,eAAX,CAEW,EAAA,IAAA,GAAAF,QAAAC,UAAA,aAAA;;uCADL,IAAI,MAAM,QAAO,CAAA,CAAA,CAAA,EAAA;AAAA;;cADIE,gBAAA,OACxBC,gBAAG,IAAI,MAAM,QAAO,CAAA,CAAA,GAAA,CAAA;AAAA;;;;;;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","_unref","_ssrRenderList","_ssrRenderAttr","_ssrInterpolate","_ssrRenderStyle","_push","_parent","_createVNode","_createTextVNode","_toDisplayString"],"sources":["../../../../components/StatsCard.vue","../../../../pages/index.vue"],"sourcesContent":["<template>\r\n  <div class=\"card flex items-center gap-4\">\r\n    <div class=\"w-12 h-12 rounded-full flex items-center justify-center\" :class=\"colorClass\">\r\n      <component :is=\"icon\" class=\"w-6 h-6\" />\r\n    </div>\r\n    <div>\r\n      <p class=\"text-sm text-text-secondary\">{{ title }}</p>\r\n      <p class=\"text-2xl font-semibold text-text-primary\">{{ value }}</p>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\nimport { computed } from 'vue'\r\nimport { BookOpen, ShoppingBag, Users, DollarSign } from 'lucide-vue-next'\r\n\r\nconst props = defineProps({\r\n  title: String,\r\n  value: [String, Number],\r\n  type: String\r\n})\r\n\r\nconst icon = computed(() => {\r\n  if (props.type === 'books') return BookOpen\r\n  if (props.type === 'orders') return ShoppingBag\r\n  if (props.type === 'users') return Users\r\n  if (props.type === 'revenue') return DollarSign\r\n  return BookOpen\r\n})\r\n\r\nconst colorClass = computed(() => {\r\n  if (props.type === 'books') return 'bg-blue-100 text-blue-600'\r\n  if (props.type === 'orders') return 'bg-amber-100 text-amber-600'\r\n  if (props.type === 'users') return 'bg-purple-100 text-purple-600'\r\n  if (props.type === 'revenue') return 'bg-green-100 text-green-600'\r\n  return 'bg-gray-100 text-gray-600'\r\n})\r\n</script>\r\n","<template>\r\n  <div class=\"space-y-6\">\r\n    <!-- Stats Row -->\r\n    <div class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6\">\r\n      <StatsCard title=\"Total Books\" :value=\"stats.totalBooks\" type=\"books\" />\r\n      <StatsCard title=\"Total Orders\" :value=\"stats.totalOrders\" type=\"orders\" />\r\n      <StatsCard title=\"Total Users\" :value=\"stats.totalUsers\" type=\"users\" />\r\n      <StatsCard title=\"Total Revenue\" :value=\"`$${stats.totalRevenue.toLocaleString()}`\" type=\"revenue\" />\r\n    </div>\r\n    \r\n    <!-- Charts Row -->\r\n    <div class=\"grid grid-cols-1 lg:grid-cols-2 gap-6\">\r\n      <!-- Orders Line Chart -->\r\n      <div class=\"card flex flex-col\">\r\n        <h3 class=\"text-lg font-semibold text-text-primary mb-4\">Orders Overview</h3>\r\n        <div class=\"flex-1 relative min-h-[250px] w-full\">\r\n          <svg viewBox=\"0 0 700 250\" class=\"w-full h-full\" preserveAspectRatio=\"none\">\r\n            <!-- Grid lines -->\r\n            <line v-for=\"i in 5\" :key=\"`h-${i}`\" x1=\"0\" :y1=\"(i-1)*50 + 10\" x2=\"700\" :y2=\"(i-1)*50 + 10\" stroke=\"#E5E7EB\" stroke-width=\"1\" />\r\n            \r\n            <!-- Line -->\r\n            <polyline \r\n              fill=\"none\" \r\n              stroke=\"#059669\" \r\n              stroke-width=\"3\" \r\n              :points=\"linePoints\" \r\n              stroke-linejoin=\"round\"\r\n              stroke-linecap=\"round\"\r\n            />\r\n            \r\n            <!-- Points -->\r\n            <circle \r\n              v-for=\"(point, idx) in points\" \r\n              :key=\"`p-${idx}`\"\r\n              :cx=\"point.x\" \r\n              :cy=\"point.y\" \r\n              r=\"4\" \r\n              fill=\"#059669\" \r\n              stroke=\"#FFFFFF\" \r\n              stroke-width=\"2\" \r\n            />\r\n            \r\n            <!-- X-Axis Labels -->\r\n            <text \r\n              v-for=\"(label, idx) in chartData.labels\" \r\n              :key=\"`l-${idx}`\"\r\n              :x=\"idx * 110 + 20\" \r\n              y=\"240\" \r\n              fill=\"#6B7280\" \r\n              font-size=\"12\"\r\n              font-family=\"sans-serif\"\r\n            >\r\n              {{ label }}\r\n            </text>\r\n          </svg>\r\n        </div>\r\n      </div>\r\n      \r\n      <!-- Categories Donut Chart -->\r\n      <div class=\"card flex flex-col\">\r\n        <h3 class=\"text-lg font-semibold text-text-primary mb-4\">Books by Category</h3>\r\n        <div class=\"flex-1 flex items-center justify-center gap-8\">\r\n          <svg viewBox=\"0 0 200 200\" class=\"w-48 h-48\">\r\n            <g transform=\"translate(100, 100)\">\r\n              <path \r\n                v-for=\"(slice, idx) in donutSlices\" \r\n                :key=\"`slice-${idx}`\"\r\n                :d=\"slice.path\"\r\n                :fill=\"slice.color\"\r\n              />\r\n              <!-- Inner hole for donut -->\r\n              <circle cx=\"0\" cy=\"0\" r=\"60\" fill=\"#FFFFFF\" />\r\n              <text x=\"0\" y=\"0\" text-anchor=\"middle\" dominant-baseline=\"middle\" font-size=\"24\" font-weight=\"600\" fill=\"#1C1C1E\">\r\n                {{ stats.totalBooks }}\r\n              </text>\r\n              <text x=\"0\" y=\"20\" text-anchor=\"middle\" dominant-baseline=\"middle\" font-size=\"12\" fill=\"#6B7280\">\r\n                Books\r\n              </text>\r\n            </g>\r\n          </svg>\r\n          \r\n          <div class=\"space-y-2\">\r\n            <div v-for=\"(slice, idx) in donutSlices\" :key=\"`leg-${idx}`\" class=\"flex items-center gap-2\">\r\n              <div class=\"w-3 h-3 rounded-full\" :style=\"{ backgroundColor: slice.color }\"></div>\r\n              <span class=\"text-sm text-text-secondary\">{{ slice.label }}</span>\r\n              <span class=\"text-sm font-semibold text-text-primary ml-auto\">{{ slice.value }}</span>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    \r\n    <!-- Recent Orders -->\r\n    <div class=\"card !p-0 overflow-hidden\">\r\n      <div class=\"p-6 border-b border-border flex justify-between items-center\">\r\n        <h3 class=\"text-lg font-semibold text-text-primary\">Recent Orders</h3>\r\n        <NuxtLink to=\"/orders\" class=\"text-sm text-primary hover:underline\">View All</NuxtLink>\r\n      </div>\r\n      <DataTable \r\n        :columns=\"orderColumns\" \r\n        :rows=\"recentOrders\" \r\n      >\r\n        <template #status=\"{ row }\">\r\n          <StatusBadge :status=\"row.status\" />\r\n        </template>\r\n        <template #total=\"{ row }\">\r\n          ${{ row.total.toFixed(2) }}\r\n        </template>\r\n      </DataTable>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\nimport { computed } from 'vue'\r\n\r\nconst { stats, chartData, orders, categories } = useMockData()\r\n\r\nconst recentOrders = computed(() => orders.slice(0, 5))\r\n\r\nconst orderColumns = [\r\n  { key: 'id', label: 'Order ID' },\r\n  { key: 'customer', label: 'Customer' },\r\n  { key: 'date', label: 'Date' },\r\n  { key: 'total', label: 'Total' },\r\n  { key: 'status', label: 'Status' }\r\n]\r\n\r\n// Line chart points calculation\r\nconst maxOrder = Math.max(...chartData.orders)\r\nconst points = computed(() => {\r\n  return chartData.orders.map((val, idx) => {\r\n    return {\r\n      x: idx * 110 + 20,\r\n      y: 200 - (val / maxOrder) * 180 + 10\r\n    }\r\n  })\r\n})\r\n\r\nconst linePoints = computed(() => {\r\n  return points.value.map(p => `${p.x},${p.y}`).join(' ')\r\n})\r\n\r\n// Donut chart calculation\r\nconst categoryColors = ['#059669', '#3B82F6', '#F59E0B', '#8B5CF6', '#EC4899', '#6B7280']\r\nconst donutSlices = computed(() => {\r\n  let total = categories.reduce((sum, cat) => sum + cat.books, 0)\r\n  let currentAngle = 0\r\n  \r\n  return categories.map((cat, idx) => {\r\n    const angle = (cat.books / total) * Math.PI * 2\r\n    const startX = Math.sin(currentAngle) * 100\r\n    const startY = -Math.cos(currentAngle) * 100\r\n    currentAngle += angle\r\n    const endX = Math.sin(currentAngle) * 100\r\n    const endY = -Math.cos(currentAngle) * 100\r\n    \r\n    const largeArcFlag = angle > Math.PI ? 1 : 0\r\n    \r\n    return {\r\n      label: cat.name,\r\n      value: cat.books,\r\n      color: categoryColors[idx % categoryColors.length],\r\n      path: `M 0 0 L ${startX} ${startY} A 100 100 0 ${largeArcFlag} 1 ${endX} ${endY} Z`\r\n    }\r\n  })\r\n})\r\n</script>\r\n"],"version":3}