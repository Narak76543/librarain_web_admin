{"file":"StatusBadge-ayQFkwOT.js","mappings":";;;;;;;;;;;;AAYA,UAAM,QAAQ;AAOd,UAAM,gBAAgB,SAAS,MAAM;AACnC,UAAI,OAAO,MAAM,WAAW,WAAW;AACrC,eAAO,MAAM,SAAS,WAAW;AAAA,MACnC;AACA,aAAO,MAAM;AAAA,IACf,CAAC;AAED,UAAM,aAAa,SAAS,MAAM;AAChC,YAAM,IAAI,OAAO,cAAc,KAAK,EAAE,YAAW;AACjD,UAAI,MAAM,eAAe,MAAM,UAAU;AACvC,eAAO;AAAA,MACT;AACA,UAAI,MAAM,cAAc;AACtB,eAAO;AAAA,MACT;AACA,UAAI,MAAM,WAAW;AACnB,eAAO;AAAA,MACT;AACA,UAAI,MAAM,eAAe,MAAM,SAAS;AACtC,eAAO;AAAA,MACT;AACA,aAAO;AAAA,IACT,CAAC;;;QAvCG,OAAK,CAAC,2EACE,WAAA,KAAU;AAAA,oCAEf,cAAA,KAAa;;;;;;;;;;","names":[],"sources":["../../../../components/StatusBadge.vue"],"sourcesContent":["<template>\r\n  <span \r\n    class=\"px-2.5 py-1 rounded-full text-xs font-semibold inline-flex items-center\"\r\n    :class=\"badgeClass\"\r\n  >\r\n    {{ displayStatus }}\r\n  </span>\r\n</template>\r\n\r\n<script setup>\r\nimport { computed } from 'vue'\r\n\r\nconst props = defineProps({\r\n  status: {\r\n    type: [String, Boolean],\r\n    required: true\r\n  }\r\n})\r\n\r\nconst displayStatus = computed(() => {\r\n  if (typeof props.status === 'boolean') {\r\n    return props.status ? 'Active' : 'Inactive'\r\n  }\r\n  return props.status\r\n})\r\n\r\nconst badgeClass = computed(() => {\r\n  const s = String(displayStatus.value).toLowerCase()\r\n  if (s === 'delivered' || s === 'active') {\r\n    return 'bg-primary-light text-primary'\r\n  }\r\n  if (s === 'processing') {\r\n    return 'bg-amber-100 text-amber-700'\r\n  }\r\n  if (s === 'pending') {\r\n    return 'bg-blue-100 text-blue-700'\r\n  }\r\n  if (s === 'cancelled' || s === 'error') {\r\n    return 'bg-red-100 text-error'\r\n  }\r\n  return 'bg-gray-100 text-text-secondary'\r\n})\r\n</script>\r\n"],"version":3}