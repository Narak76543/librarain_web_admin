{"file":"_id_-BJxaxZiA.js","mappings":";;;;;;;;;;;;;;;;;;;AAqCkB,QAAI,IAAI;AAC1B,UAAM,aAAa,IAAI,KAAK;AAC5B,UAAM,aAAa,IAAI,IAAI;;;QArCvB,QAAM,iKAA+J,EAAA,mCACxH,kBAAU,gCAAA,CAAmC,WAAA,UAAe,WAAA,MAAU,CAAA;AAAA;UAcnG,WAAA,OAAU;AAClB,cAAA,eAAAA,cAAA,OAAK,WAAA,KAAU,CAAA,8PAAA;AAAA;;AAOV,cAAAC,mBAAAC,MAAA,SAAA,GAAA,EAAA,OAAM,qCAAoC,GAAA,MAAA,OAAA,CAAA;;;;;;;;;;;;;;;;;AC0F3D,UAAM,QAAQ,SAAQ;AACtB,UAAM,EAAE,OAAO,WAAU,IAAK,YAAW;AAEzC,UAAM,YAAY,SAAS,MAAM,MAAM,OAAO,OAAO,KAAK;AAC1D,UAAM,OAAO,SAAS,MAAM;AAC1B,UAAI,CAAC,UAAU,MAAO,QAAO,CAAA;AAC7B,aAAO,MAAM,KAAK,OAAK,EAAE,OAAO,MAAM,OAAO,EAAE,KAAK,MAAM,CAAC;AAAA,IAC7D,CAAC;;;;AAzHM,YAAA,OAAAC,eAAAC,WAAA,EAAA,OAAM,yBAAqB,MAAA,CAAA,CAAA,wCAAA;;QAElB,IAAG;AAAA,QAAS,OAAM;AAAA;yBAA5B,CAEW,GAAAC,QAAAC,UAAA,aAAA;;AADE,YAAAD,OAAAJ,mBAAAC,MAAA,SAAA,GAAA,EAAA,OAAM,iCAA6B,MAAAI,UAAA,QAAA,CAAA;AAAA;;cAA9CC,YAAiDL,MAAA,SAAA,GAAA,EAAtC,OAAM,8BAA6B,CAAA;AAAA;;;;;kFAEO,UAAA,QAAS,cAAA,cAAA,yTASQF,cAAA,SAAO,UAAA,QAAY,KAAA,MAAK,QAAK,EAAA,iKAK5BA,cAAA,SAAO,UAAA,QAAY,KAAA,MAAK,SAAM,EAAA;AAOzEQ,oBAAAN,MAAA,UAAA,IAAP,QAAG;sCAA+B,SAAO,IAAI,IAAI,IAAaO,sBAAA,UAAA,SAAa,KAAA,MAAK,aAAa,IAAI,IAAI,IAAA,cAAA,MAC/GC,eAAA,IAAI,IAAI;;yrBAsBqDV,cAAA,SAAO,UAAA,QAAY,KAAA,MAAK,QAAK,EAAA,kJAK5CA,cAAA,SAAO,UAAA,QAAY,KAAA,MAAK,QAAK,EAAA;;8WAoC1B,UAAA,QAAY,KAAA,MAAK,SAAM,IAAA,IAAA,aAAA,EAAA,kaAAA;;QAOvE,IAAG;AAAA,QAAS,OAAM;AAAA;yBAA5B,CAEW,GAAAK,QAAAC,UAAA,aAAA;;;;;8BAFkL,UAE7L;AAAA;;;;;iEAEK,UAAA,QAAS,iBAAA,aAAA,CAAA,mCAAA;AAAA;;;;;;;;;","names":["_ssrRenderAttr","_ssrRenderComponent","_unref","_ssrRenderAttrs","_mergeProps","_push","_parent","_createVNode","_ssrRenderList","_ssrIncludeBooleanAttr","_ssrInterpolate"],"sources":["../../../../components/ImageUpload.vue","../../../../pages/books/[id].vue"],"sourcesContent":["<template>\n  <div \n    class=\"h-[200px] border-2 border-dashed border-border rounded-xl flex flex-col items-center justify-center cursor-pointer transition-colors relative overflow-hidden\"\n    :class=\"{ 'border-primary bg-primary-light': isDragging, 'bg-surface hover:bg-gray-100': !isDragging && !previewUrl }\"\n    @dragover.prevent=\"isDragging = true\"\n    @dragleave.prevent=\"isDragging = false\"\n    @drop.prevent=\"handleDrop\"\n    @click=\"$refs.fileInput.click()\"\n  >\n    <input \n      type=\"file\" \n      ref=\"fileInput\" \n      class=\"hidden\" \n      accept=\"image/*\"\n      @change=\"handleFileSelect\"\n    />\n    \n    <template v-if=\"previewUrl\">\n      <img :src=\"previewUrl\" class=\"w-full h-full object-contain\" alt=\"Preview\" />\n      <div class=\"absolute inset-0 bg-black/40 opacity-0 hover:opacity-100 transition-opacity flex items-center justify-center\">\n        <span class=\"text-white font-medium text-sm\">Change Image</span>\n      </div>\n    </template>\n    \n    <template v-else>\n      <BookImage class=\"w-10 h-10 text-text-secondary mb-3\" />\n      <p class=\"text-sm font-medium text-text-primary\">Click or drag to upload</p>\n      <p class=\"text-xs text-text-secondary mt-1\">SVG, PNG, JPG or GIF (max. 2MB)</p>\n    </template>\n  </div>\n</template>\n\n<script setup>\nimport { ref } from 'vue'\nimport { BookImage } from 'lucide-vue-next'\n\nconst emit = defineEmits(['file-selected'])\nconst fileInput = ref(null)\nconst isDragging = ref(false)\nconst previewUrl = ref(null)\n\nconst processFile = (file) => {\n  if (file && file.type.startsWith('image/')) {\n    previewUrl.value = URL.createObjectURL(file)\n    emit('file-selected', file)\n  }\n  isDragging.value = false\n}\n\nconst handleDrop = (e) => {\n  processFile(e.dataTransfer.files[0])\n}\n\nconst handleFileSelect = (e) => {\n  processFile(e.target.files[0])\n}\n</script>\n","<template>\n  <div class=\"space-y-6 max-w-6xl\">\n    <div class=\"flex items-center gap-4\">\n      <NuxtLink to=\"/books\" class=\"w-10 h-10 flex items-center justify-center rounded-full hover:bg-surface transition-colors\">\n        <ArrowLeft class=\"w-5 h-5 text-text-secondary\" />\n      </NuxtLink>\n      <h2 class=\"text-xl font-semibold text-text-primary\">{{ isEditing ? 'Edit Book' : 'Add New Book' }}</h2>\n    </div>\n    \n    <div class=\"flex flex-col lg:flex-row gap-6\">\n      <!-- Form Fields Left 2/3 -->\n      <div class=\"lg:w-2/3 card\">\n        <div class=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\n          <div class=\"md:col-span-2\">\n            <label class=\"block text-sm font-medium text-text-secondary mb-1\">Book Title</label>\n            <input type=\"text\" class=\"w-full\" placeholder=\"Enter book title\" :value=\"isEditing ? book.title : ''\" />\n          </div>\n          \n          <div>\n            <label class=\"block text-sm font-medium text-text-secondary mb-1\">Author</label>\n            <input type=\"text\" class=\"w-full\" placeholder=\"Enter author name\" :value=\"isEditing ? book.author : ''\" />\n          </div>\n          \n          <div>\n            <label class=\"block text-sm font-medium text-text-secondary mb-1\">Category</label>\n            <select class=\"w-full\">\n              <option value=\"\">Select category</option>\n              <option v-for=\"cat in categories\" :key=\"cat.id\" :value=\"cat.name\" :selected=\"isEditing && book.category === cat.name\">\n                {{ cat.name }}\n              </option>\n            </select>\n          </div>\n          \n          <div>\n            <label class=\"block text-sm font-medium text-text-secondary mb-1\">ISBN</label>\n            <input type=\"text\" class=\"w-full\" placeholder=\"ISBN-13\" />\n          </div>\n          \n          <div>\n            <label class=\"block text-sm font-medium text-text-secondary mb-1\">Publisher</label>\n            <input type=\"text\" class=\"w-full\" placeholder=\"Publisher name\" />\n          </div>\n          \n          <div class=\"md:col-span-2\">\n            <label class=\"block text-sm font-medium text-text-secondary mb-1\">Description</label>\n            <textarea class=\"w-full h-32 py-2\" placeholder=\"Write a short summary...\"></textarea>\n          </div>\n          \n          <div>\n            <label class=\"block text-sm font-medium text-text-secondary mb-1\">Price ($)</label>\n            <input type=\"number\" step=\"0.01\" class=\"w-full\" placeholder=\"0.00\" :value=\"isEditing ? book.price : ''\" />\n          </div>\n          \n          <div>\n            <label class=\"block text-sm font-medium text-text-secondary mb-1\">Stock</label>\n            <input type=\"number\" class=\"w-full\" placeholder=\"0\" :value=\"isEditing ? book.stock : ''\" />\n          </div>\n          \n          <div>\n            <label class=\"block text-sm font-medium text-text-secondary mb-1\">Pages</label>\n            <input type=\"number\" class=\"w-full\" placeholder=\"Number of pages\" />\n          </div>\n          \n          <div>\n            <label class=\"block text-sm font-medium text-text-secondary mb-1\">Language</label>\n            <select class=\"w-full\">\n              <option value=\"english\">English</option>\n              <option value=\"spanish\">Spanish</option>\n              <option value=\"french\">French</option>\n            </select>\n          </div>\n          \n          <div>\n            <label class=\"block text-sm font-medium text-text-secondary mb-1\">Published Date</label>\n            <input type=\"date\" class=\"w-full\" />\n          </div>\n        </div>\n      </div>\n      \n      <!-- Sidebar Right 1/3 -->\n      <div class=\"lg:w-1/3 flex flex-col gap-6\">\n        <div class=\"card\">\n          <h3 class=\"text-sm font-medium text-text-secondary mb-4\">Cover Image</h3>\n          <ImageUpload />\n        </div>\n        \n        <div class=\"card\">\n          <h3 class=\"text-sm font-medium text-text-secondary mb-4\">Publishing Status</h3>\n          <div class=\"flex items-center justify-between\">\n            <span class=\"text-sm font-medium text-text-primary\">Active Status</span>\n            <label class=\"relative inline-flex items-center cursor-pointer\">\n              <input type=\"checkbox\" class=\"sr-only peer\" :checked=\"isEditing ? book.status : true\">\n              <div class=\"w-9 h-5 bg-gray-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-primary\"></div>\n            </label>\n          </div>\n        </div>\n        \n        <div class=\"flex items-center gap-4\">\n          <NuxtLink to=\"/books\" class=\"flex-1 h-10 flex items-center justify-center rounded-lg border border-border bg-white text-sm font-medium text-text-primary hover:bg-surface transition-colors\">\n            Cancel\n          </NuxtLink>\n          <button class=\"flex-1 btn-primary\">\n            {{ isEditing ? 'Save Changes' : 'Create Book' }}\n          </button>\n        </div>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script setup>\nimport { computed } from 'vue'\nimport { useRoute } from 'vue-router'\nimport { ArrowLeft } from 'lucide-vue-next'\n\nconst route = useRoute()\nconst { books, categories } = useMockData()\n\nconst isEditing = computed(() => route.params.id !== 'new')\nconst book = computed(() => {\n  if (!isEditing.value) return {}\n  return books.find(b => b.id === route.params.id) || books[0]\n})\n</script>\n"],"version":3}