{"file":"_id_-BJxaxZiA.js","mappings":";;;;;;;;;;;;;;;;;;;AAqCkB,QAAI,IAAI;AAC1B,UAAM,aAAa,IAAI,KAAK;AAC5B,UAAM,aAAa,IAAI,IAAI;;;QArCvB,QAAM,iKAA+J,EAAA,mCACxH,kBAAU,gCAAA,CAAmC,WAAA,UAAe,WAAA,MAAU,CAAA;AAAA;UAcnG,WAAA,OAAU;AAClB,cAAA,eAAAA,cAAA,OAAK,WAAA,KAAU,CAAA,8PAAA;AAAA;;AAOV,cAAAC,mBAAAC,MAAA,SAAA,GAAA,EAAA,OAAM,qCAAoC,GAAA,MAAA,OAAA,CAAA;;;;;;;;;;;;;;;;;AC0F3D,UAAM,QAAQ,SAAQ;AACtB,UAAM,EAAE,OAAO,WAAU,IAAK,YAAW;AAEzC,UAAM,YAAY,SAAS,MAAM,MAAM,OAAO,OAAO,KAAK;AAC1D,UAAM,OAAO,SAAS,MAAM;AAC1B,UAAI,CAAC,UAAU,MAAO,QAAO,CAAA;AAC7B,aAAO,MAAM,KAAK,OAAK,EAAE,OAAO,MAAM,OAAO,EAAE,KAAK,MAAM,CAAC;AAAA,IAC7D,CAAC;;;;AAzHM,YAAA,OAAAC,eAAAC,WAAA,EAAA,OAAM,yBAAqB,MAAA,CAAA,CAAA,wCAAA;;QAElB,IAAG;AAAA,QAAS,OAAM;AAAA;yBAA5B,CAEW,GAAAC,QAAAC,UAAA,aAAA;;AADE,YAAAD,OAAAJ,mBAAAC,MAAA,SAAA,GAAA,EAAA,OAAM,iCAA6B,MAAAI,UAAA,QAAA,CAAA;AAAA;;cAA9CC,YAAiDL,MAAA,SAAA,GAAA,EAAtC,OAAM,8BAA6B,CAAA;AAAA;;;;;kFAEO,UAAA,QAAS,cAAA,cAAA,yTASQF,cAAA,SAAO,UAAA,QAAY,KAAA,MAAK,QAAK,EAAA,iKAK5BA,cAAA,SAAO,UAAA,QAAY,KAAA,MAAK,SAAM,EAAA;AAOzEQ,oBAAAN,MAAA,UAAA,IAAP,QAAG;sCAA+B,SAAO,IAAI,IAAI,IAAaO,sBAAA,UAAA,SAAa,KAAA,MAAK,aAAa,IAAI,IAAI,IAAA,cAAA,MAC/GC,eAAA,IAAI,IAAI;;yrBAsBqDV,cAAA,SAAO,UAAA,QAAY,KAAA,MAAK,QAAK,EAAA,kJAK5CA,cAAA,SAAO,UAAA,QAAY,KAAA,MAAK,QAAK,EAAA;;8WAoC1B,UAAA,QAAY,KAAA,MAAK,SAAM,IAAA,IAAA,aAAA,EAAA,kaAAA;;QAOvE,IAAG;AAAA,QAAS,OAAM;AAAA;yBAA5B,CAEW,GAAAK,QAAAC,UAAA,aAAA;;;;;8BAFkL,UAE7L;AAAA;;;;;iEAEK,UAAA,QAAS,iBAAA,aAAA,CAAA,mCAAA;AAAA;;;;;;;;;","names":["_ssrRenderAttr","_ssrRenderComponent","_unref","_ssrRenderAttrs","_mergeProps","_push","_parent","_createVNode","_ssrRenderList","_ssrIncludeBooleanAttr","_ssrInterpolate"],"sources":["../../../../components/ImageUpload.vue","../../../../pages/books/[id].vue"],"sourcesContent":["<template>\r\n  <div \r\n    class=\"h-[200px] border-2 border-dashed border-border rounded-xl flex flex-col items-center justify-center cursor-pointer transition-colors relative overflow-hidden\"\r\n    :class=\"{ 'border-primary bg-primary-light': isDragging, 'bg-surface hover:bg-gray-100': !isDragging && !previewUrl }\"\r\n    @dragover.prevent=\"isDragging = true\"\r\n    @dragleave.prevent=\"isDragging = false\"\r\n    @drop.prevent=\"handleDrop\"\r\n    @click=\"$refs.fileInput.click()\"\r\n  >\r\n    <input \r\n      type=\"file\" \r\n      ref=\"fileInput\" \r\n      class=\"hidden\" \r\n      accept=\"image/*\"\r\n      @change=\"handleFileSelect\"\r\n    />\r\n    \r\n    <template v-if=\"previewUrl\">\r\n      <img :src=\"previewUrl\" class=\"w-full h-full object-contain\" alt=\"Preview\" />\r\n      <div class=\"absolute inset-0 bg-black/40 opacity-0 hover:opacity-100 transition-opacity flex items-center justify-center\">\r\n        <span class=\"text-white font-medium text-sm\">Change Image</span>\r\n      </div>\r\n    </template>\r\n    \r\n    <template v-else>\r\n      <BookImage class=\"w-10 h-10 text-text-secondary mb-3\" />\r\n      <p class=\"text-sm font-medium text-text-primary\">Click or drag to upload</p>\r\n      <p class=\"text-xs text-text-secondary mt-1\">SVG, PNG, JPG or GIF (max. 2MB)</p>\r\n    </template>\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\nimport { ref } from 'vue'\r\nimport { BookImage } from 'lucide-vue-next'\r\n\r\nconst emit = defineEmits(['file-selected'])\r\nconst fileInput = ref(null)\r\nconst isDragging = ref(false)\r\nconst previewUrl = ref(null)\r\n\r\nconst processFile = (file) => {\r\n  if (file && file.type.startsWith('image/')) {\r\n    previewUrl.value = URL.createObjectURL(file)\r\n    emit('file-selected', file)\r\n  }\r\n  isDragging.value = false\r\n}\r\n\r\nconst handleDrop = (e) => {\r\n  processFile(e.dataTransfer.files[0])\r\n}\r\n\r\nconst handleFileSelect = (e) => {\r\n  processFile(e.target.files[0])\r\n}\r\n</script>\r\n","<template>\r\n  <div class=\"space-y-6 max-w-6xl\">\r\n    <div class=\"flex items-center gap-4\">\r\n      <NuxtLink to=\"/books\" class=\"w-10 h-10 flex items-center justify-center rounded-full hover:bg-surface transition-colors\">\r\n        <ArrowLeft class=\"w-5 h-5 text-text-secondary\" />\r\n      </NuxtLink>\r\n      <h2 class=\"text-xl font-semibold text-text-primary\">{{ isEditing ? 'Edit Book' : 'Add New Book' }}</h2>\r\n    </div>\r\n    \r\n    <div class=\"flex flex-col lg:flex-row gap-6\">\r\n      <!-- Form Fields Left 2/3 -->\r\n      <div class=\"lg:w-2/3 card\">\r\n        <div class=\"grid grid-cols-1 md:grid-cols-2 gap-6\">\r\n          <div class=\"md:col-span-2\">\r\n            <label class=\"block text-sm font-medium text-text-secondary mb-1\">Book Title</label>\r\n            <input type=\"text\" class=\"w-full\" placeholder=\"Enter book title\" :value=\"isEditing ? book.title : ''\" />\r\n          </div>\r\n          \r\n          <div>\r\n            <label class=\"block text-sm font-medium text-text-secondary mb-1\">Author</label>\r\n            <input type=\"text\" class=\"w-full\" placeholder=\"Enter author name\" :value=\"isEditing ? book.author : ''\" />\r\n          </div>\r\n          \r\n          <div>\r\n            <label class=\"block text-sm font-medium text-text-secondary mb-1\">Category</label>\r\n            <select class=\"w-full\">\r\n              <option value=\"\">Select category</option>\r\n              <option v-for=\"cat in categories\" :key=\"cat.id\" :value=\"cat.name\" :selected=\"isEditing && book.category === cat.name\">\r\n                {{ cat.name }}\r\n              </option>\r\n            </select>\r\n          </div>\r\n          \r\n          <div>\r\n            <label class=\"block text-sm font-medium text-text-secondary mb-1\">ISBN</label>\r\n            <input type=\"text\" class=\"w-full\" placeholder=\"ISBN-13\" />\r\n          </div>\r\n          \r\n          <div>\r\n            <label class=\"block text-sm font-medium text-text-secondary mb-1\">Publisher</label>\r\n            <input type=\"text\" class=\"w-full\" placeholder=\"Publisher name\" />\r\n          </div>\r\n          \r\n          <div class=\"md:col-span-2\">\r\n            <label class=\"block text-sm font-medium text-text-secondary mb-1\">Description</label>\r\n            <textarea class=\"w-full h-32 py-2\" placeholder=\"Write a short summary...\"></textarea>\r\n          </div>\r\n          \r\n          <div>\r\n            <label class=\"block text-sm font-medium text-text-secondary mb-1\">Price ($)</label>\r\n            <input type=\"number\" step=\"0.01\" class=\"w-full\" placeholder=\"0.00\" :value=\"isEditing ? book.price : ''\" />\r\n          </div>\r\n          \r\n          <div>\r\n            <label class=\"block text-sm font-medium text-text-secondary mb-1\">Stock</label>\r\n            <input type=\"number\" class=\"w-full\" placeholder=\"0\" :value=\"isEditing ? book.stock : ''\" />\r\n          </div>\r\n          \r\n          <div>\r\n            <label class=\"block text-sm font-medium text-text-secondary mb-1\">Pages</label>\r\n            <input type=\"number\" class=\"w-full\" placeholder=\"Number of pages\" />\r\n          </div>\r\n          \r\n          <div>\r\n            <label class=\"block text-sm font-medium text-text-secondary mb-1\">Language</label>\r\n            <select class=\"w-full\">\r\n              <option value=\"english\">English</option>\r\n              <option value=\"spanish\">Spanish</option>\r\n              <option value=\"french\">French</option>\r\n            </select>\r\n          </div>\r\n          \r\n          <div>\r\n            <label class=\"block text-sm font-medium text-text-secondary mb-1\">Published Date</label>\r\n            <input type=\"date\" class=\"w-full\" />\r\n          </div>\r\n        </div>\r\n      </div>\r\n      \r\n      <!-- Sidebar Right 1/3 -->\r\n      <div class=\"lg:w-1/3 flex flex-col gap-6\">\r\n        <div class=\"card\">\r\n          <h3 class=\"text-sm font-medium text-text-secondary mb-4\">Cover Image</h3>\r\n          <ImageUpload />\r\n        </div>\r\n        \r\n        <div class=\"card\">\r\n          <h3 class=\"text-sm font-medium text-text-secondary mb-4\">Publishing Status</h3>\r\n          <div class=\"flex items-center justify-between\">\r\n            <span class=\"text-sm font-medium text-text-primary\">Active Status</span>\r\n            <label class=\"relative inline-flex items-center cursor-pointer\">\r\n              <input type=\"checkbox\" class=\"sr-only peer\" :checked=\"isEditing ? book.status : true\">\r\n              <div class=\"w-9 h-5 bg-gray-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-primary\"></div>\r\n            </label>\r\n          </div>\r\n        </div>\r\n        \r\n        <div class=\"flex items-center gap-4\">\r\n          <NuxtLink to=\"/books\" class=\"flex-1 h-10 flex items-center justify-center rounded-lg border border-border bg-white text-sm font-medium text-text-primary hover:bg-surface transition-colors\">\r\n            Cancel\r\n          </NuxtLink>\r\n          <button class=\"flex-1 btn-primary\">\r\n            {{ isEditing ? 'Save Changes' : 'Create Book' }}\r\n          </button>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script setup>\r\nimport { computed } from 'vue'\r\nimport { useRoute } from 'vue-router'\r\nimport { ArrowLeft } from 'lucide-vue-next'\r\n\r\nconst route = useRoute()\r\nconst { books, categories } = useMockData()\r\n\r\nconst isEditing = computed(() => route.params.id !== 'new')\r\nconst book = computed(() => {\r\n  if (!isEditing.value) return {}\r\n  return books.find(b => b.id === route.params.id) || books[0]\r\n})\r\n</script>\r\n"],"version":3}