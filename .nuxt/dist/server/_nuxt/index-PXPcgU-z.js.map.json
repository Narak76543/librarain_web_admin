MAAA,IAAA,GAAA,EAA5C,OAAM,oCAAmC,CAAA;AAAA,gBAC/CK,YAA6C,UAAvC,OAAM,UAAS,GAAAC,gBAAI,IAAI,MAAM,GAAA,CAAA;AAAA;;;;QAI5B,gBAAX,CAKW,EAAA,IAAA,GAAAH,QAAAC,UAAA,aAAA;;4IAH+CI,sBAAA,IAAI,MAAM,IAAA,aAAA;;;cADlEH,YAGQ,SAAA,EAHD,OAAM,mDAAkD,GAAA;AAAA,gBAC7DA,YAAkE,SAAA;AAAA,kBAA3D,MAAK;AAAA,kBAAW,OAAM;AAAA,kBAAgB,SAAS,IAAI;AAAA;gBAC1DA,YAA8V,OAAA,EAAzV,OAAM,6UAA4U,CAAA;AAAA;;;;QAIhV,iBAAX,CASW,EAAA,IAAA,GAAAF,QAAAC,UAAA,aAAA;;;;cAPI,IAAE,UAAY,IAAI,EAAE;AAAA,cAAI,OAAM;AAAA;+BAAzC,CAEW,GAAAD,QAAAC,UAAAK,cAAA;;AADF,kBAAAN,OAAAJ,mBAAAC,MAAA,KAAA,GAAA,EAAA,OAAM,aAAS,MAAAI,UAAAK,SAAA,CAAA;AAAA;;oBAAtBJ,YAAyBL,MAAA,KAAA,GAAA,EAAlB,OAAM,UAAS,CAAA;AAAA;;;;;;AAGd,YAAAG,OAAAJ,mBAAAC,MAAA,MAAA,GAAA,EAAA,OAAM,aAAS,MAAAI,UAAA,QAAA,CAAA;;;;cAL3BC,YAOM,OAAA,EAPD,OAAM,0BAAyB,GAAA;AAAA,gBAClCA,YAEW,qBAAA;AAAA,kBAFA,IAAE,UAAY,IAAI,EAAE;AAAA,kBAAI,OAAM;AAAA;mCACvC,MAAyB;AAAA,oBAAzBA,YAAyBL,MAAA,KAAA,GAAA,EAAlB,OAAM,UAAS,CAAA;AAAA;;;gBAExBK,YAES,UAAA;AAAA,kBAFA,SAAK,YAAE,cAAc,GAAG;AAAA,kBAAG,OAAM;AAAA;kBACxCA,YAA0BL,MAAA,MAAA,GAAA,EAAlB,OAAM,UAAS,CAAA;AAAA;;;;;;;;UAQzB,gBAAA,OAAe;;UACrB,OAAM;AAAA,UACL,SAAO,oCAAsC,aAAA,OAAc,KAAK;AAAA,UACjE,cAAa;AAAA,UACZ,WAAS;AAAA,UACT,sBAAQ,gBAAA,QAAe;AAAA;;;;;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","_ssrRenderComponent","_unref","_ssrRenderList","_ssrInterpolate","_push","_parent","_createVNode","_toDisplayString","_createTextVNode","_ssrIncludeBooleanAttr","_scopeId"],"sources":["../../../../pages/books/index.vue"],"sourcesContent":["<template>\n  <div class=\"space-y-6\">\n    <div class=\"flex items-center justify-between\">\n      <div class=\"flex items-center gap-4\">\n        <div class=\"relative\">\n          <Search class=\"w-4 h-4 text-text-secondary absolute left-3 top-1/2 -translate-y-1/2\" />\n          <input type=\"text\" placeholder=\"Search books...\" class=\"pl-9 w-64 bg-white\" />\n        </div>\n        \n        <select class=\"bg-white min-w-[150px]\">\n          <option value=\"\">All Categories</option>\n          <option v-for=\"cat in categories\" :key=\"cat.id\" :value=\"cat.id\">{{ cat.name }}</option>\n        </select>\n        \n        <select class=\"bg-white min-w-[120px]\">\n          <option value=\"\">All Status</option>\n          <option value=\"active\">Active</option>\n          <option value=\"inactive\">Inactive</option>\n        </select>\n      </div>\n      \n      <NuxtLink to=\"/books/new\" class=\"btn-primary\">\n        <Plus class=\"w-4 h-4 mr-2\" />\n        Add Book\n      </NuxtLink>\n    </div>\n\n    <div class=\"card !p-0 overflow-hidden\">\n      <DataTable \n        :columns=\"columns\" \n        :rows=\"books\" \n        :total=\"243\"\n        :page=\"1\"\n        :perPage=\"10\"\n      >\n        <template #book=\"{ row }\">\n          <div class=\"flex items-center gap-4\">\n            <img :src=\"row.cover\" class=\"w-12 h-16 object-cover rounded border border-border\" />\n            <div>\n              <p class=\"font-semibold text-text-primary\">{{ row.title }}</p>\n              <p class=\"text-sm text-text-secondary\">{{ row.author }}</p>\n            </div>\n          </div>\n        </template>\n        \n        <template #category=\"{ row }\">\n          <span class=\"px-2 py-1 bg-surface text-text-secondary rounded text-xs\">{{ row.category }}</span>\n        </template>\n        \n        <template #price=\"{ row }\">\n          ${{ row.price.toFixed(2) }}\n        </template>\n        \n        <template #rating=\"{ row }\">\n          <div class=\"flex items-center gap-1\">\n            <Star class=\"w-4 h-4 text-warning fill-warning\" />\n            <span class=\"text-sm\">{{ row.rating }}</span>\n          </div>\n        </template>\n        \n        <template #status=\"{ row }\">\n          <label class=\"relative inline-flex items-center cursor-pointer\">\n            <input type=\"checkbox\" class=\"sr-only peer\" :checked=\"row.status\">\n            <div class=\"w-9 h-5 bg-gray-200 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-primary\"></div>\n          </label>\n        </template>\n        \n        <template #actions=\"{ row }\">\n          <div class=\"flex items-center gap-2\">\n            <NuxtLink :to=\"`/books/${row.id}`\" class=\"w-8 h-8 flex items-center justify-center rounded hover:bg-surface text-text-secondary hover:text-info transition-colors\">\n              <Edit2 class=\"w-4 h-4\" />\n            </NuxtLink>\n            <button @click=\"confirmDelete(row)\" class=\"w-8 h-8 flex items-center justify-center rounded hover:bg-surface text-text-secondary hover:text-error transition-colors\">\n              <Trash2 class=\"w-4 h-4\" />\n            </button>\n          </div>\n        </template>\n      </DataTable>\n    </div>\n    \n    <ConfirmModal \n      v-if=\"showDeleteModal\"\n      title=\"Delete Book\"\n      :message=\"`Are you sure you want to delete '${bookToDelete?.title}'? This action cannot be undone.`\"\n      confirmLabel=\"Delete\"\n      @confirm=\"handleDelete\"\n      @cancel=\"showDeleteModal = false\"\n    />\n  </div>\n</template>\n\n<script setup>\nimport { ref } from 'vue'\nimport { Search, Plus, Star, Edit2, Trash2 } from 'lucide-vue-next'\n\nconst { books, categories } = useMockData()\n\nconst columns = [\n  { key: 'book', label: 'Book' },\n  { key: 'category', label: 'Category' },\n  { key: 'price', label: 'Price' },\n  { key: 'stock', label: 'Stock' },\n  { key: 'rating', label: 'Rating' },\n  { key: 'status', label: 'Status' },\n  { key: 'actions', label: 'Actions' }\n]\n\nconst showDeleteModal = ref(false)\nconst bookToDelete = ref(null)\n\nconst confirmDelete = (book) => {\n  bookToDelete.value = book\n  showDeleteModal.value = true\n}\n\nconst handleDelete = () => {\n  // Mock delete\n  showDeleteModal.value = false\n  bookToDelete.value = null\n}\n</script>\n"],"version":3}